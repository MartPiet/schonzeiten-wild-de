{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/MartPiet/schonzeiten-wild-de/main/schema/schonzeit.schema.json",
  "title": "Schonzeiten-Region",
  "description": "Jagd- und Schonzeiten einer Region (Bundesland / Kanton / Bund).",
  "type": "object",
  "required": ["region", "stand", "arten"],
  "additionalProperties": false,
  "properties": {
    "region": {
      "type": "object",
      "required": ["code", "land", "name"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z]{2}(-[A-Z0-9]{1,3})?$", "description": "ISO-3166-artiger Code, z. B. DE, DE-BY, AT-2, CH-ZH" },
        "land": { "type": "string", "enum": ["DE", "AT", "CH"] },
        "name": { "type": "string" },
        "system": { "type": "string", "enum": ["patent", "revier", "gemischt", "verbot"], "description": "nur Schweiz: Jagdsystem des Kantons" }
      }
    },
    "stand": { "type": "string", "format": "date", "description": "Stand/Fassungsdatum der zugrunde liegenden Verordnung (JJJJ-MM-TT)" },
    "quelle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "titel": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "abgerufen": { "type": "string", "format": "date" }
      }
    },
    "confidence": { "type": "string", "enum": ["hoch", "mittel", "niedrig"], "description": "Verlässlichkeit der Daten dieser Region" },
    "hinweis": { "type": "string" },
    "arten": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["art", "jagdzeit", "ganzjaehrigGeschont"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "stabiler Slug aus Art + Klasse, generiert" },
          "art": { "type": "string", "description": "Wildart, z. B. Rehwild" },
          "klasse": { "type": "string", "description": "Geschlechts-/Altersklasse, z. B. Bock, Kitz; leer wenn keine Differenzierung" },
          "wissenschaftlich": { "type": "string" },
          "jagdzeit": {
            "type": "array",
            "description": "Zeiträume, in denen die Jagd erlaubt ist (Komplement = Schonzeit). Leer, wenn ganzjährig geschont.",
            "items": {
              "type": "object",
              "required": ["von", "bis"],
              "additionalProperties": false,
              "properties": {
                "von": { "type": "string", "pattern": "^(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$", "description": "MM-TT (jährlich wiederkehrend)" },
                "bis": { "type": "string", "pattern": "^(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$", "description": "MM-TT; kann kleiner als 'von' sein (Jahreswechsel)" }
              }
            }
          },
          "ganzjaehrigGeschont": { "type": "boolean", "description": "true = ganzjährig geschont, jagdzeit dann leer" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
